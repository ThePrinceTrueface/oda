{
  "name": "oda",
  "version": "1.0.0",
  "description": "A lightweight TypeScript HTTP client built around scoped, derivable clients. Swap the engine for any JS runtime, queue requests offline and replay them on reconnect.",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node esbuild.js --watch",
    "build": "node esbuild.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "tsx examples/basic-usage.ts",
    "release": "release-it"
  },
  "keywords": [
    "http",
    "client",
    "offline",
    "typescript",
    "fetch"
  ],
  "author": "The Prince True-face (ebinasoft)",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "release-it": "^20.0.1",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
